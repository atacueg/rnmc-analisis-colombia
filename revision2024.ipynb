   "source": [
    "import pandas as pd\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df2024 = pd.read_csv('data/rnmc2024.csv')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "df2024total = df2024[['CÓDIGO DIVIPOLA', 'Departamento', 'Municipio',\n",
    "                       'TOTAL PERSONAS COMPARENDADAS', 'TOTAL COMPARENDOS']]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "top10tasas = df2024total.nlargest(10, 'TOTAL COMPARENDOS')\n",
    "top10tasas[['CÓDIGO DIVIPOLA', 'DEPARTAMENTO', 'MUNICIPIO',\n",
    "            'TOTAL COMPARENDOS']]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "dfresultado = df2024[['CÓDIGO DIVIPOLA', 'Departamento', 'Municipio',\n",
    "                       'TOTAL PERSONAS COMPARENDADAS']]\n",
    "\n",
    "dfresultado_muni = dfresultado.groupby(['CÓDIGO DIVIPOLA', 'Departamento',\n",
    "                                         'Municipio']).sum().reset_index()\n",
    "\n",
    "municipios_con_comparendos = df2024total['CÓDIGO DIVIPOLA'].nunique()\n",
    "\n",
    "faltantes_municipios = dfresultado_muni[\n",
    "    ~dfresultado_muni['CÓDIGO DIVIPOLA'].isin(df2024total['CÓDIGO DIVIPOLA'])]\n",
    "\n",
    "faltantes_municipios = faltantes_municipios.sort_values('CÓDIGO DIVIPOLA')\n",
    "\n",
    "print('Municipios totales población:', len(dfresultado_muni))\n",
    "print('Municipios totales comparendos:', municipios_con_comparendos)\n",
    "print('Municipios faltantes:', len(faltantes_municipios))\n",
    "\n",
    "faltantes_municipios.head(20)"
   ]
  },
